# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/Salma-Portfolio?retryWrites=true&w=majority

# Gmail SMTP contact flow
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
